# Django Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=True

# API Keys
SERPAPI_API_KEY=your-serpapi-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Redis Configuration
# For local development, Redis typically runs on 127.0.0.1:6379
# For Redis Cloud, use the connection string provided by Redis Cloud
REDIS_URL=redis://default:password@host:port

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/broker_db

# Email Configuration (optional)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# CORS Settings (optional)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Allowed Hosts
# ALLOWED_HOSTS=localhost,127.0.0.1,.herokuapp.com
