# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# Database (for local development - production uses Render PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost/broker_db

# Redis/Celery
REDIS_URL=redis://default:password@host:port/0

# API Keys
GROQ_API_KEY=your-groq-api-key
SERPAPI_API_KEY=your-serpapi-api-key

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:5174

# Render Deployment Variables (set automatically by Render)
# RENDER_EXTERNAL_HOSTNAME=your-backend.onrender.com
# DATABASE_URL=postgresql://...  (set by Render PostgreSQL)
